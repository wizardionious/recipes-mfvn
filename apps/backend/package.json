{
  "name": "@recipes/backend",
  "version": "0.6.0",
  "description": "Recipes API - Node.js + Fastify + MongoDB",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "lint": "pnpm typecheck && pnpm check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui --coverage",
    "coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Artem Levchenko",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@recipes/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.3.3",
    "mongoose": "^9.3.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17"
  }
}
