{
  "name": "@recipes/backend",
  "version": "0.3.0",
  "description": "Recipes API - Node.js + Fastify + MongoDB",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "lint": "pnpm typecheck && pnpm check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Artem Levchenko",
  "license": "ISC",
  "dependencies": {
    "@recipes/shared": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3"
  }
}
