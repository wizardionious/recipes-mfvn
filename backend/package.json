{
  "name": "recipes-api",
  "version": "0.1.0",
  "description": "Recipes API - Node.js + Fastify + MongoDB",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "lint": "pnpm typecheck && pnpm check"
  },
  "keywords": [],
  "author": "Artem Levchenko",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
